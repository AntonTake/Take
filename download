
import { GoogleGenAI, Type } from "@google/genai";

const API_KEY = process.env.API_KEY || "";

export const processNewsWithAI = async (text: string, title: string) => {
  const ai = new GoogleGenAI({ apiKey: API_KEY });
  
  const prompt = `
    As an expert news editor for 2026, rephrase and summarize the following news piece for a high-engagement Telegram channel.
    Target: Professional yet engaging, emojis included, SEO-friendly.
    Identify sentiment and extract key tags.
    
    Title: ${title}
    Content: ${text}
  `;

  try {
    const response = await ai.models.generateContent({
      model: "gemini-3-flash-preview",
      contents: prompt,
      config: {
        responseMimeType: "application/json",
        responseSchema: {
          type: Type.OBJECT,
          properties: {
            processedTitle: { type: Type.STRING },
            processedText: { type: Type.STRING },
            sentiment: { type: Type.STRING, enum: ['POSITIVE', 'NEUTRAL', 'NEGATIVE'] },
            tags: { type: Type.ARRAY, items: { type: Type.STRING } }
          },
          required: ["processedTitle", "processedText", "sentiment"]
        }
      }
    });

    return JSON.parse(response.text);
  } catch (error) {
    console.error("AI Processing Error:", error);
    return null;
  }
};

export const generateNewsImage = async (prompt: string) => {
  const ai = new GoogleGenAI({ apiKey: API_KEY });
  try {
    const response = await ai.models.generateContent({
      model: 'gemini-2.5-flash-image',
      contents: {
        parts: [
          { text: `Create a futuristic, clean, digital illustration for a news post about: ${prompt}. Cinematic lighting, high quality, 16:9 aspect ratio.` }
        ]
      },
      config: {
        imageConfig: {
          aspectRatio: "16:9"
        }
      }
    });

    for (const part of response.candidates[0].content.parts) {
      if (part.inlineData) {
        return `data:image/png;base64,${part.inlineData.data}`;
      }
    }
    return null;
  } catch (error) {
    console.error("Image Generation Error:", error);
    return null;
  }
};
